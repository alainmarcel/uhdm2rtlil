            attribute \src "dut.sv:116.17-116.21"
              case 
                assign { } { }
                assign $4\DESIGN_PROCESSOR.state[0:0] \DESIGN_PROCESSOR.state
                assign $4\DESIGN_PROCESSOR.i[4:0] $add$dut.sv:117$12_Y [4:0]
            end
          case 
            assign $2\DESIGN_PROCESSOR.i[4:0] \DESIGN_PROCESSOR.i
            assign $2\DESIGN_PROCESSOR.state[0:0] \DESIGN_PROCESSOR.state
            assign $2\DESIGN_PROCESSOR.dz[19:0] \DESIGN_PROCESSOR.dz
            assign $2\DESIGN_PROCESSOR.dx[19:0] \DESIGN_PROCESSOR.dx
            assign $2\DESIGN_PROCESSOR.dy[19:0] \DESIGN_PROCESSOR.dy
            assign $2\DESIGN_PROCESSOR.y[19:0] \DESIGN_PROCESSOR.y
            assign $2\DESIGN_PROCESSOR.x[19:0] \DESIGN_PROCESSOR.x
            assign $2\DESIGN_PROCESSOR.z[19:0] \DESIGN_PROCESSOR.z
        end
    end
    sync posedge \clock
      update \cos_z0 $0\cos_z0[19:0]
      update \sin_z0 $0\sin_z0[19:0]
      update \done $0\done[0:0]
      update \DESIGN_PROCESSOR.i $0\DESIGN_PROCESSOR.i[4:0]
      update \DESIGN_PROCESSOR.state $0\DESIGN_PROCESSOR.state[0:0]
      update \DESIGN_PROCESSOR.dz $0\DESIGN_PROCESSOR.dz[19:0]
      update \DESIGN_PROCESSOR.dx $0\DESIGN_PROCESSOR.dx[19:0]
      update \DESIGN_PROCESSOR.dy $0\DESIGN_PROCESSOR.dy[19:0]
      update \DESIGN_PROCESSOR.y $0\DESIGN_PROCESSOR.y[19:0]
      update \DESIGN_PROCESSOR.x $0\DESIGN_PROCESSOR.x[19:0]
      update \DESIGN_PROCESSOR.z $0\DESIGN_PROCESSOR.z[19:0]
    sync posedge \reset
      update \cos_z0 $0\cos_z0[19:0]
      update \sin_z0 $0\sin_z0[19:0]
      update \done $0\done[0:0]
      update \DESIGN_PROCESSOR.i $0\DESIGN_PROCESSOR.i[4:0]
      update \DESIGN_PROCESSOR.state $0\DESIGN_PROCESSOR.state[0:0]
      update \DESIGN_PROCESSOR.dz $0\DESIGN_PROCESSOR.dz[19:0]
      update \DESIGN_PROCESSOR.dx $0\DESIGN_PROCESSOR.dx[19:0]
      update \DESIGN_PROCESSOR.dy $0\DESIGN_PROCESSOR.dy[19:0]
      update \DESIGN_PROCESSOR.y $0\DESIGN_PROCESSOR.y[19:0]
      update \DESIGN_PROCESSOR.x $0\DESIGN_PROCESSOR.x[19:0]
      update \DESIGN_PROCESSOR.z $0\DESIGN_PROCESSOR.z[19:0]
  end
end

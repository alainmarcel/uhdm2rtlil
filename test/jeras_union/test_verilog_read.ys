# Test script to read Verilog file directly in Yosys
read_verilog -sv riscv_isa_pkg.sv test_union.sv
# Write RTLIL immediately after reading, before hierarchy
write_rtlil jeras_union_from_verilog_nohier.il
hierarchy -check -auto-top
stat
proc
opt
stat
write_rtlil jeras_union_from_verilog.il
# Synthesize to gate-level netlist
synth -auto-top
write_verilog -noexpr jeras_union_from_verilog_synth.v

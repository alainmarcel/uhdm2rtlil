# Test script to read Verilog file directly in Yosys
read_verilog -sv tcb_if.sv tcb_gpio.sv tcb_gpio_wrap.sv
# Write RTLIL immediately after reading, before hierarchy
write_rtlil jeras_tcb_gpio_from_verilog_nohier.il
hierarchy -check -auto-top
stat
proc
opt
stat
write_rtlil jeras_tcb_gpio_from_verilog.il
# Synthesize to gate-level netlist
synth -auto-top
write_verilog -noexpr jeras_tcb_gpio_from_verilog_synth.v

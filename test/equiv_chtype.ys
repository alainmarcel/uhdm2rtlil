chtype -map \$_SDFFE_NN0N_ $_SDFFE_NN0N_
chtype -map \$_SDFFE_NN1P_ $_SDFFE_NN1P_
chtype -map \$_SDFFE_NN1N_ $_SDFFE_NN1N_
chtype -map \$_SDFFCE_PP0P_ $_SDFFCE_PP0P_
